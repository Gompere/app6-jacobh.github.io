<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My GitHub Page</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background-color: #f4f4f4;
      color: #333;
    }
    header {
      background-color: #24292e;
      color: #fff;
      padding: 1rem;
      text-align: center;
    }
    main {
      max-width: 800px;
      margin: 2rem auto;
      background: #fff;
      padding: 2rem;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    h1 {
      margin-top: 0;
    }
    .video {
      margin-top: 1.5rem;
      text-align: center;
    }
    iframe {
      width: 100%;
      height: 450px;
      border: none;
      border-radius: 6px;
    }
    footer {
      text-align: center;
      margin: 2rem 0;
      color: #666;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>Welcome to My Project</h1>
  </header>
  <main>
    <p>Hello! This is my GitHub Pages site. Here’s an embedded YouTube video below:</p>
    <div class="video">
      <!-- Replace VIDEO_ID with the actual YouTube video ID -->
      <iframe 
        src="[youtube.com](https://www.youtube.com/embed/VIDEO_ID)" 
        title="YouTube video player" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen></iframe>
    </div>
  </main>
  <footer>
    <p>© 2026 Jacob Henderson — Built using GitHub Pages</p>
  </footer>
</body>
</html>
